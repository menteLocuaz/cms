{
  "name": "cms-builder-php/cms-builder-php",
  "description": "CMS Builder PHP",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "nesbot/carbon": "^3.0",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^6.10"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "scripts": {
    "serve": "php -S localhost:6060 serve-router.php",
    "test": "phpunit --colors=always",
    "stan": "phpstan analyse app --level=5",
    "cs": "phpcs --standard=PSR12 app",
    "cs:fix": "phpcbf --standard=PSR12 app"
  }
}
