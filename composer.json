{
  "name": "cms-builder-php/cms-builder-php",
  "description": "CMS Builder PHP",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "nesbot/carbon": "^3.0",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^6.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
    "scripts": {
        "serve": "php -S localhost:6060 serve-router.php"
    }
}
